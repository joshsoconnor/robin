<animated-vector xmlns:android="http://schemas.android.com/apk/res/android" xmlns:aapt="http://schemas.android.com/aapt">
   <aapt:attr name="android:drawable">
       <vector android:height="20dp" android:width="50dp" android:viewportHeight="20" android:viewportWidth="50">
           <!-- Filled circle modRed600 - see go/geo-gm2-spec -->
           <group android:name="circle" android:scaleX="0" android:scaleY="0" android:pivotX="25" android:pivotY="10">
               <path android:name="circle_path" android:fillAlpha="0" android:fillColor="#D93025" android:pathData="M25 0c-5.52 0 -10 4.48 -10 10s4.48 10 10 10c5.52 0 10 -4.48 10 -10s-4.48 -10 -10 -10z"/>
           </group>
       </vector>
   </aapt:attr>

   <!-- Circle animation to red fill the button -->
   <target android:name="circle">
       <aapt:attr name="android:animation">
           <set android:ordering="together">
               <objectAnimator android:duration="350" android:interpolator="@android:interpolator/fast_out_slow_in" android:propertyName="scaleX" android:valueFrom="0" android:valueTo="3"/>
               <objectAnimator android:duration="350" android:interpolator="@android:interpolator/fast_out_slow_in" android:propertyName="scaleY" android:valueFrom="0" android:valueTo="3"/>
         </set>
       </aapt:attr>
   </target>

   <target android:name="circle_path">
       <aapt:attr name="android:animation">
           <objectAnimator android:duration="350" android:interpolator="@android:interpolator/fast_out_slow_in" android:propertyName="fillAlpha" android:valueFrom="0" android:valueTo="1"/>
       </aapt:attr>
   </target>
</animated-vector>