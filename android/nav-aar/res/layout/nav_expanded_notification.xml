<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/notification_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="64dp">
    <ImageView android:id="@+id/nav_notification_icon" android:layout_width="@android:dimen/notification_large_icon_width" android:layout_height="@android:dimen/notification_large_icon_height" android:scaleType="center" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="12dp"/>
    <LinearLayout style="@style/NavNotificationContentContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="12dp" android:paddingEnd="24dp">
        <LinearLayout style="@style/NavNotificationContentLine" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:orientation="vertical">
            <TextView android:id="@+id/nav_title" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom" android:textColor="#FFFFFF" android:textSize="16dp" android:singleLine="true" android:ellipsize="marquee" android:textAlignment="viewStart" tools:ignore="RtlCompat"/>
            <TextView android:id="@+id/nav_description" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:minLines="2" android:maxLines="2" android:textColor="#FFFFFF" android:textSize="16dp" android:textAlignment="viewStart" tools:ignore="RtlCompat"/>
            <TextView android:id="@+id/nav_time" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="top" android:textColor="#FFFFFF" android:textSize="14dp" android:singleLine="true" android:textAlignment="viewStart" tools:ignore="RtlCompat"/>
        </LinearLayout>
        </LinearLayout>
</RelativeLayout>